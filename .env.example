# ============================================================================
# AI HR PILOT — environment variables
# Copy to .env.local for local dev. Production values live in Vercel.
# Run `vercel env pull` to get the auto-provisioned values (DB, Blob, OIDC).
# ============================================================================

# -- Database (Neon via Vercel Marketplace; auto-provisioned) --
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# -- Auth (Clerk) --
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=              # REQUIRED in production: webhook fails closed without it
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=/onboarding
# CLERK_WEBHOOK_SECRET_SKIP_VERIFY=true   # DEV ONLY; ignored in production

# -- File storage (Vercel Blob; auto-provisioned) --
BLOB_READ_WRITE_TOKEN=

# -- AI (Vercel AI Gateway; OIDC token auto-provisioned on deploy) --
VERCEL_OIDC_TOKEN=
AI_MODEL=anthropic/claude-sonnet-4-6           # gateway slug; override to upgrade models
EMBED_MODEL=openai/text-embedding-3-small      # 1536 dims; must match document_chunks schema
CHAT_RATE_LIMIT=20                             # user messages per minute

# -- Payments (Stripe; prices resolve server-side from lib/data/plans.js) --
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# -- Email (Resend) --
RESEND_API_KEY=

# -- Error tracking (Sentry). Fully optional: unset = Sentry is a no-op. --
SENTRY_DSN=                                    # server/edge DSN
NEXT_PUBLIC_SENTRY_DSN=                         # browser DSN (usually same project)
# SENTRY_ORG=                                   # only needed for source-map upload
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=                            # build-time source-map upload
# SENTRY_TRACES_SAMPLE_RATE=0.1

# -- One-time schema setup endpoint (/api/setup) --
SETUP_SECRET=

# -- Drip engine (outbound email sequences; server-to-server) --
DRIP_ENGINE_URL=
DRIP_INGEST_SECRET=
